<nav class="sticky top-0 z-50 bg-white border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">

      <div class="flex items-center gap-4">
        <button class="p-2 -ml-2 text-slate-600 hover:text-slate-900 lg:hidden" aria-label="Menu" id="mobile-menu-btn">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
        <svg class="w-5 h-5 text-slate-600 hidden lg:block cursor-pointer hover:text-slate-900" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/>
        </svg>
      </div>

      <div class="flex-1 flex justify-center">
        <a href="{{ routes.root_url }}" class="text-xl font-bold tracking-tight text-slate-900 uppercase">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="h-8 w-auto">
          {%- else -%}
            {{ section.settings.brand_name | default: shop.name }}
          {%- endif -%}
        </a>
      </div>

      <div class="flex items-center gap-4">
        <a href="{{ routes.cart_url }}" class="p-2 -mr-2 text-slate-600 hover:text-slate-900 relative" aria-label="Cart">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="absolute top-1 right-1 w-4 h-4 bg-red-500 text-white text-[10px] font-bold flex items-center justify-center rounded-full">
              {{ cart.item_count }}
            </span>
          {%- endif -%}
        </a>
      </div>

    </div>
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name (if no logo)",
      "default": "Circadian Shield"
    }
  ],
  "presets": [
    { "name": "Header" }
  ]
}
{% endschema %}
