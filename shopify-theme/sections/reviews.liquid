<section class="py-24 bg-white border-t border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <h2 class="text-sm font-bold tracking-widest uppercase text-slate-500 mb-3">{{ section.settings.eyebrow | default: 'Customer Reviews' }}</h2>
      <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">{{ section.settings.heading | default: 'Real results from real sleepers.' }}</h3>
      <div class="flex items-center justify-center gap-3">
        <div class="flex gap-1 text-yellow-400">
          {%- for i in (1..5) -%}
            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {%- endfor -%}
        </div>
        <span class="text-2xl font-bold text-slate-900">{{ section.settings.avg_rating | default: '4.9' }}</span>
        <span class="text-slate-500 text-sm">({{ section.settings.review_count | default: '12' }} verified reviews)</span>
      </div>
    </div>

    <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 space-y-6">
      {%- for row in reviews -%}
        {%- assign cols = row | split: '|' -%}
        {%- if cols.size >= 6 -%}
          {%- assign r_name = cols[0] | strip -%}
          {%- assign r_loc = cols[1] | strip -%}
          {%- assign r_rating = cols[2] | strip | times: 1 -%}
          {%- assign r_title = cols[3] | strip -%}
          {%- assign r_body = cols[4] | strip -%}
          {%- assign r_days = cols[5] | strip -%}
          {%- if r_name != '' -%}
            <div class="break-inside-avoid bg-slate-50 border border-slate-200 rounded-2xl p-6 cs-fade-in">
              <div class="flex items-start justify-between mb-3">
                <div class="flex gap-0.5 text-yellow-400">
                  {%- for s in (1..5) -%}
                    <svg class="w-4 h-4 {% if s <= r_rating %}fill-current{% else %}fill-none stroke-current text-slate-200{% endif %}" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  {%- endfor -%}
                </div>
                <span class="text-[10px] font-bold uppercase tracking-wider text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full">Verified</span>
              </div>
              <h4 class="font-bold text-slate-900 mb-2">{{ r_title }}</h4>
              <p class="text-slate-600 text-sm leading-relaxed mb-4">{{ r_body }}</p>
              <div class="flex items-center justify-between text-xs text-slate-400">
                <span class="font-semibold text-slate-700">{{ r_name }} · {{ r_loc }}</span>
                <span>{{ r_days }}d ago</span>
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Customer Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real results from real sleepers." },
    { "type": "text", "id": "avg_rating", "label": "Average rating", "default": "4.9" },
    { "type": "text", "id": "review_count", "label": "Review count label", "default": "12" }
  ],
  "presets": [
    { "name": "Reviews" }
  ]
}
{% endschema %}
