<section class="border-y border-slate-200 bg-white py-10">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-slate-200">

      <div class="flex flex-col items-center text-center gap-3 px-6 py-6 sm:py-2">
        <svg viewBox="0 0 48 48" fill="none" class="w-10 h-10" aria-hidden="true">
          <rect width="48" height="48" rx="24" fill="#f1f5f9"/>
          <path d="M10 18h28M10 18v16a2 2 0 002 2h24a2 2 0 002-2V18M10 18l4-6h20l4 6" stroke="#334155" stroke-width="2" stroke-linejoin="round"/>
          <path d="M20 30l3 3 6-6" stroke="#334155" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <h4 class="font-bold text-slate-900 text-sm uppercase tracking-wide">{{ section.settings.item1_heading | default: 'Free Shipping' }}</h4>
        <p class="text-slate-500 text-xs leading-relaxed max-w-xs">{{ section.settings.item1_body | default: 'Every order ships free — no minimum, no catch. Straight to your door.' }}</p>
      </div>

      <div class="flex flex-col items-center text-center gap-3 px-6 py-6 sm:py-2">
        <svg viewBox="0 0 48 48" fill="none" class="w-10 h-10" aria-hidden="true">
          <rect width="48" height="48" rx="24" fill="#f1f5f9"/>
          <rect x="8" y="20" width="26" height="16" rx="2" stroke="#334155" stroke-width="2"/>
          <path d="M34 26h4a2 2 0 012 2v6a2 2 0 01-2 2h-4" stroke="#334155" stroke-width="2"/>
          <circle cx="14" cy="39" r="2.5" fill="#f1f5f9" stroke="#334155" stroke-width="2"/>
          <circle cx="28" cy="39" r="2.5" fill="#f1f5f9" stroke="#334155" stroke-width="2"/>
          <path d="M8 24l4-8h14" stroke="#334155" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <h4 class="font-bold text-slate-900 text-sm uppercase tracking-wide">{{ section.settings.item2_heading | default: 'Fast Delivery' }}</h4>
        <p class="text-slate-500 text-xs leading-relaxed max-w-xs">{{ section.settings.item2_body | default: 'Dispatched in 1–2 business days. Arrives in 4–7 business days.' }}</p>
      </div>

      <div class="flex flex-col items-center text-center gap-3 px-6 py-6 sm:py-2">
        <svg viewBox="0 0 48 48" fill="none" class="w-10 h-10" aria-hidden="true">
          <rect width="48" height="48" rx="24" fill="#f1f5f9"/>
          <rect x="8" y="15" width="32" height="20" rx="3" stroke="#334155" stroke-width="2"/>
          <path d="M8 21h32" stroke="#334155" stroke-width="2"/>
          <rect x="12" y="26" width="8" height="4" rx="1" fill="#334155"/>
        </svg>
        <h4 class="font-bold text-slate-900 text-sm uppercase tracking-wide">{{ section.settings.item3_heading | default: 'Secure Payments' }}</h4>
        <p class="text-slate-500 text-xs leading-relaxed max-w-xs">{{ section.settings.item3_body | default: 'Checkout with Visa, Mastercard, Amex, PayPal, or Shop Pay — 100% encrypted.' }}</p>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Strip",
  "settings": [
    { "type": "text", "id": "item1_heading", "label": "Item 1 heading", "default": "Free Shipping" },
    { "type": "text", "id": "item1_body", "label": "Item 1 body", "default": "Every order ships free — no minimum, no catch. Straight to your door." },
    { "type": "text", "id": "item2_heading", "label": "Item 2 heading", "default": "Fast Delivery" },
    { "type": "text", "id": "item2_body", "label": "Item 2 body", "default": "Dispatched in 1–2 business days. Arrives in 4–7 business days." },
    { "type": "text", "id": "item3_heading", "label": "Item 3 heading", "default": "Secure Payments" },
    { "type": "text", "id": "item3_body", "label": "Item 3 body", "default": "Checkout with Visa, Mastercard, Amex, PayPal, or Shop Pay — 100% encrypted." }
  ],
  "presets": [
    { "name": "Trust Strip" }
  ]
}
{% endschema %}
