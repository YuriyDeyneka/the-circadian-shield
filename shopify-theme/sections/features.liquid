<section class="py-20 bg-slate-50 border-t border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-sm font-bold tracking-widest uppercase text-slate-500 mb-3">{{ section.settings.eyebrow | default: 'The Biological Override' }}</h2>
      <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">{{ section.settings.heading | default: 'Engineered to silence your environment.' }}</h3>
      <p class="text-lg text-slate-600">{{ section.settings.subheading | default: 'White noise not only promotes deep sleep — it covers the interference of external noise to help you focus on studying and working. One device. Two superpowers.' }}</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

      {%- assign feature_icons = 'mute,laptop,flame,music,brain,baby' | split: ',' -%}
      {%- for i in (1..6) -%}
        {%- assign title_key = 'feature' | append: i | append: '_title' -%}
        {%- assign sub_key = 'feature' | append: i | append: '_subtitle' -%}
        {%- assign desc_key = 'feature' | append: i | append: '_desc' -%}
        <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm text-center flex flex-col items-center hover:shadow-md transition-shadow cs-fade-in">
          <div class="w-16 h-16 bg-slate-100 text-slate-900 rounded-full flex items-center justify-center mb-6">
            {%- case forloop.index0 -%}
              {%- when 0 -%}
                <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="1" y1="1" x2="23" y2="23"/><path d="M9 9v3a3 3 0 005.12 2.12M15 9.34V4a3 3 0 00-5.94-.6"/><path d="M17 16.95A7 7 0 015 12v-2m14 0v2a7 7 0 01-.11 1.23M12 19v3M8 23h8"/></svg>
              {%- when 1 -%}
                <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              {%- when 2 -%}
                <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/></svg>
              {%- when 3 -%}
                <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/></svg>
              {%- when 4 -%}
                <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              {%- when 5 -%}
                <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            {%- endcase -%}
          </div>
          <h4 class="text-lg font-bold text-slate-900 mb-1">{{ section.settings[title_key] }}</h4>
          <p class="text-slate-500 text-xs font-bold uppercase tracking-wider mb-4">{{ section.settings[sub_key] }}</p>
          <p class="text-slate-600 text-sm leading-relaxed">{{ section.settings[desc_key] }}</p>
        </div>
      {%- endfor -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Biological Override" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Engineered to silence your environment." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "White noise not only promotes deep sleep — it covers the interference of external noise to help you focus on studying and working. One device. Two superpowers." },
    { "type": "header", "content": "Feature 1" },
    { "type": "text", "id": "feature1_title", "label": "Title", "default": "Invisible Sound Wall" },
    { "type": "text", "id": "feature1_subtitle", "label": "Subtitle", "default": "Dual-Sync White Noise Tech" },
    { "type": "textarea", "id": "feature1_desc", "label": "Description", "default": "Drowns out sirens, barking dogs, thin walls, and office chatter — the external interference that fragments both your sleep and your focus." },
    { "type": "header", "content": "Feature 2" },
    { "type": "text", "id": "feature2_title", "label": "Title", "default": "Deep Work Mode" },
    { "type": "text", "id": "feature2_subtitle", "label": "Subtitle", "default": "Focus as Hard as You Sleep" },
    { "type": "textarea", "id": "feature2_desc", "label": "Description", "default": "White noise doesn't just promote sleep — it masks distracting interruptions so you enter flow state faster and stay there longer while studying or working." },
    { "type": "header", "content": "Feature 3" },
    { "type": "text", "id": "feature3_title", "label": "Title", "default": "Anti-Blue Light Shield" },
    { "type": "text", "id": "feature3_subtitle", "label": "Subtitle", "default": "Biological Red-Spectrum Glow" },
    { "type": "textarea", "id": "feature3_desc", "label": "Description", "default": "Signals your primitive brain to start melatonin production immediately, bypassing the \"Circadian Corruption\" caused by phone screens." },
    { "type": "header", "content": "Feature 4" },
    { "type": "text", "id": "feature4_title", "label": "Title", "default": "12 Clinically-Mapped Soundscapes" },
    { "type": "text", "id": "feature4_subtitle", "label": "Subtitle", "default": "Not Cheap Radio Loops" },
    { "type": "textarea", "id": "feature4_desc", "label": "Description", "default": "Engineered specifically to bypass the \"High Alert\" state of a stressed nervous system and trigger deep Delta-wave sleep — or peak cognitive flow." },
    { "type": "header", "content": "Feature 5" },
    { "type": "text", "id": "feature5_title", "label": "Title", "default": "Nervous System Reset" },
    { "type": "text", "id": "feature5_subtitle", "label": "Subtitle", "default": "From Alert to Calm in Minutes" },
    { "type": "textarea", "id": "feature5_desc", "label": "Description", "default": "The same low-frequency hum that quiets your mind at night also lowers cortisol during high-pressure work sessions, protecting your focus and your health." },
    { "type": "header", "content": "Feature 6" },
    { "type": "text", "id": "feature6_title", "label": "Title", "default": "The \"Parental Peace\" Mode" },
    { "type": "text", "id": "feature6_subtitle", "label": "Subtitle", "default": "Portable & Breathing Guided" },
    { "type": "textarea", "id": "feature6_desc", "label": "Description", "default": "Designed specifically for \"shushing fatigue\" and keeping the baby asleep during those critical, short sleep windows." }
  ],
  "presets": [
    { "name": "Features" }
  ]
}
{% endschema %}
